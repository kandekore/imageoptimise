# Server
PORT=4000
NODE_ENV=development

# CORS (frontend origin)
CORS_ORIGIN=http://localhost:5173

# Upload limits
MAX_FILE_SIZE_MB=25
MAX_FILES_PER_REQUEST=200

# Processing concurrency
PROCESSING_CONCURRENCY=4

# Cleanup: delete temp files older than N minutes
CLEANUP_MAX_AGE_MINUTES=60
CLEANUP_INTERVAL_MINUTES=15

# Storage mode: "local" or "ftp"
STORAGE_MODE=local

# FTP (only used when STORAGE_MODE=ftp)
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=
FTP_SECURE=false
FTP_REMOTE_DIR=/public_html/uploads/processed/
